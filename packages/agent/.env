# 1inch API Configuration
# Get your API key from: https://portal.1inch.dev/dashboard
ONEINCH_API_KEY=

# Chain ID (1 for Ethereum Mainnet, 10143 for Monad Testnet)
CHAIN_ID=1

# Agent Server Port
PORT=4000

# Monad Testnet RPC URL (optional, required for on-chain simulation on Monad)
MONAD_TESTNET_RPC_URL=

# Simulation sender address (optional, defaults to 1inch router)
SIMULATION_FROM_ADDRESS=

# 1inch API Base URL (optional)
ONEINCH_API_BASE=https://api.1inch.dev/swap/v5.2

# Slippage tolerance for swap (optional, defaults to 1%)
ONEINCH_SWAP_SLIPPAGE=1
